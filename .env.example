# ── Hex API ─────────────────────────────────────────────────────────────────
# Create a token at: https://app.hex.tech → Settings → API Keys
# Use a Workspace token (hxtw_...) for scheduled automation or a
# Personal access token (hxtp_...) for personal use.
HEX_API_TOKEN=hxtw_your_token_here

# The project ID is found via: open the Hex app → ⋮ menu → "Copy project id"
# The project URL is: https://app.hex.tech/redis/app/AI-usage-032EARbPw0YYLaJdMcBxfj/latest
HEX_PROJECT_ID=your_project_uuid_here

# Name of the Hex input-parameter that filters by team leader.
# Open the Hex notebook, look for an Input Cell; use its variable name here.
HEX_INPUT_PARAM_NAME=team_leader_name

# Base URL for the Hex API (change only for EU / single-tenant workspaces)
HEX_BASE_URL=https://app.hex.tech/api/v1

# How long (seconds) to wait for a Hex run to finish before giving up
HEX_RUN_TIMEOUT=300

# ── SMTP / Email ─────────────────────────────────────────────────────────────
# Examples:
#   Gmail:   smtp.gmail.com  port 587  (use an App Password, not your login password)
#   Outlook: smtp.office365.com  port 587
#   SES:     email-smtp.<region>.amazonaws.com  port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sending_address@example.com
SMTP_PASSWORD=your_smtp_password_or_app_password

# The "From" display name and address that recipients will see
SENDER_NAME=AI Usage Reports
SENDER_EMAIL=your_sending_address@example.com

# ── Dev / Testing ────────────────────────────────────────────────────────────
# Set to "true" to skip the Hex API entirely and return a placeholder report.
# Useful for testing the Slack bot before the Hex token is available.
MOCK_MODE=false

# Chrome remote debugging port used by the screenshot generator.
CHROME_DEBUG_PORT=9222

# Optional: override the Chrome user-data directory used for Hex login/session state.
# On macOS, if unset, the project uses:
#   ~/Library/Application Support/AI Usage Chrome Debug
CHROME_USER_DATA=

# ── Slack Bot ────────────────────────────────────────────────────────────────
# Bot token:  Slack App → OAuth & Permissions → Bot Token (xoxb-...)
# App token:  Slack App → Basic Information → App-Level Tokens (xapp-...)
#             The app-level token needs the "connections:write" scope.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Restrict the bot to a specific channel (recommended).
# Right-click the channel in Slack → "Copy link" – the ID is the last segment (e.g. C12345678).
# Leave empty to let the bot respond in any channel it is invited to.
SLACK_CHANNEL_ID=C12345678

# Cached reports are stored here on the running machine.
REPORTS_DIR=.hex_reports

# Set to "true" on long-running cloud deployments that should only serve
# already-generated reports from Google Drive.
SERVE_ONLY=false

# Google Drive folder that stores the generated PNG reports.
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Either point to a service-account JSON file...
GOOGLE_DRIVE_CREDENTIALS=/absolute/path/to/service-account.json

# ...or paste the full JSON as a single-line secret env var (useful on env0).
GOOGLE_DRIVE_CREDENTIALS_JSON=

# ── Scheduler ────────────────────────────────────────────────────────────────
# Day of the week to send reports: monday | tuesday | ... | sunday
SCHEDULE_DAY=monday

# Time of day to send (24-hour HH:MM, server local time)
SCHEDULE_TIME=08:00

# Path to the JSON file that lists team leaders (name + email)
TEAM_LEADERS_FILE=team_leaders.json

# Optional: paste the full team leader JSON as a single-line env var.
# Useful for env0 when team_leaders.json is not committed to git.
TEAM_LEADERS_JSON=
